{
    "name": "fueleu-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/infrastructure/server/server.ts",
        "build": "tsc",
        "test": "jest --runInBand",
        "test:unit": "jest --testPathPattern=unit",
        "test:int": "jest --testPathPattern=integration",
        "migrate": "prisma migrate dev",
        "seed": "ts-node src/infrastructure/db/prisma/seed.ts",
        "lint": "eslint src --ext .ts",
        "prisma:generate": "prisma generate"
    },
    "dependencies": {
        "@prisma/client": "^5.10.2",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "uuid": "^9.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.30",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^9.0.8",
        "@typescript-eslint/eslint-plugin": "^7.3.1",
        "@typescript-eslint/parser": "^7.3.1",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "prisma": "^5.10.2",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.2"
    }
}